# Stage 1 knowledge separation: personal knowledge never leaves this machine
knowledge/personal/*
!knowledge/personal/README.md
!knowledge/personal/.gitkeep

# Local run logs are per-user learning data (templates stay tracked)
runs/*
!runs/README.md
!runs/run-log-template.md

# Project board state is machine-local runtime coordination data
project-board/*
!project-board/README.md
artifacts/project-board/*

# Personal agent memory is machine-local (contract doc stays tracked)
memory/*
!memory/README.md

# Chat history is local per-user data (same privacy class as runs/)
chat/history/
chat/sessions.json

# Local backups
backups/

# Skill hub: personal skills are private, activation symlinks are per-machine
skills/personal/*
!skills/personal/.gitkeep
skills/personal-*/
.claude/skills/
.skill-profile

# Plugin state + generated MCP config are machine-local
interface/plugins.json
.mcp.json

# Guardrails configuration is per-machine (materialized into settings.local.json)
interface/guardrails.json
.claude/settings.local.json

# Workflow edits (overrides / custom / deleted) are machine-local state
interface/workflows.json
interface/provider-settings.json
interface/app-settings.json

# Scheduler jobs/runs/logs are machine-local state
scheduler/*
!scheduler/README.md

# Per-user custom instructions (created by /personal-onboarding)
CLAUDE.local.md

# Local env files
.env
.env.local

# Local JS dependencies
node_modules/

# Local deep-work orchestration state
.slim/deepwork/

# OS/editor noise
.DS_Store
**/.DS_Store
