{
  "$schema": "https://opencode.ai/config.json",
  "model": "azure/gpt-5.6-sol",
  "plugin": [
    "../../../.opencode/plugins/claude-agent-adapter.js"
  ],
  "provider": {
    "azure": {
      "models": {
        "gpt-5.6-sol": {
          "name": "GPT-5.6 Sol",
          "family": "gpt-5.6",
          "release_date": "2026-07-09",
          "reasoning": true,
          "tool_call": true,
          "status": "active"
        },
        "gpt-5.6-terra": {
          "name": "GPT-5.6 Terra",
          "family": "gpt-5.6",
          "release_date": "2026-07-09",
          "reasoning": true,
          "tool_call": true,
          "status": "active"
        },
        "gpt-5.6-luna": {
          "name": "GPT-5.6 Luna",
          "family": "gpt-5.6",
          "release_date": "2026-07-09",
          "reasoning": true,
          "tool_call": true,
          "status": "active"
        }
      }
    }
  },
  "mcp": {
    "twenty": {
      "type": "remote",
      "url": "https://crm.smapas.com/mcp",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {env:TWENTY_API_KEY}"
      }
    }
  },
  "agent": {
    "build": {
      "model": "azure/gpt-5.3-codex",
      "variant": "medium"
    },
    "fixer": {
      "model": "azure/gpt-5.3-codex",
      "variant": "medium"
    },
    "oracle": {
      "model": "azure/gpt-5.6-sol"
    },
    "designer": {
      "model": "github-copilot/gemini-3.1-pro-preview"
    }
  }
}
