# Optional runtime label used in server logs
STEADYMADE_RUNTIME=dev

# Knowledge backend: fs | graph
STEADYMADE_KNOWLEDGE_BACKEND=fs

# Filesystem backend root. Absolute path or path relative to apps/internal/steadymade-ai-os.
# Default fallback: knowledge
STEADYMADE_KNOWLEDGE_FS_ROOT=knowledge

# Microsoft Graph backend (required when STEADYMADE_KNOWLEDGE_BACKEND=graph)
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
GRAPH_DRIVE_ID=

# Folder path inside the Graph drive that maps to the app's virtual knowledge/ root
GRAPH_KNOWLEDGE_ROOT=AI_OS/knowledge
